# --- Stripe (required for deposit checkout + webhook) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- App base URL (used for callback URL building) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Supabase ---
# Server-side (service role)
SUPABASE_URL=https://replace-me.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# --- CRM integration (website -> invoice/CRM) ---
CRM_INTEGRATION_BASE_URL=https://crm-staging.example.com
CRM_INTEGRATION_SHARED_SECRET=replace_me
CRM_INTEGRATION_PARTNER_ID=official_website
CRM_INTEGRATION_SOURCE=official_website
CRM_INTEGRATION_REPLAY_TOKEN=replace_me
CRM_INTEGRATION_MAX_ATTEMPTS=10

# Client-side (anon)
NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me

# --- Optional: email notifications ---
RESEND_API_KEY=re_replace_me
EMAIL_FROM=support@realhibachi.com
EMAIL_TO=support@realhibachi.com

# --- Optional: invoice self-service deep-link ---
# Used by /deposit/success CTA and webhook customer notifications.
NEXT_PUBLIC_INVOICE_SELF_SERVICE_BASE_URL=https://invoice.example.com/self-service
# Server-side override for webhook notifications (falls back to NEXT_PUBLIC_* when unset).
INVOICE_SELF_SERVICE_BASE_URL=https://invoice.example.com/self-service

# --- Optional: SMS notifications (Sendly/Twilio compatibility layer) ---
SMS_PROVIDER=auto
SENDLY_API_KEY=sk_test_v1_key_replace_me
SENDLY_API_URL=https://sendly.live/api/v1/messages
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+12135551234

# --- Optional: GTM ---
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Optional: external live chat widget ---
# Example local: http://localhost:3300
NEXT_PUBLIC_LIVECHAT_BASE_URL=

# --- Optional: GA4 Measurement Protocol fallback (server-side deposit_completed) ---
# Used by app/api/stripe/webhook/route.ts -> lib/ga4-measurement-protocol.ts
# If unset, server-side fallback tracking is skipped safely.
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_MP_API_SECRET=replace_me
# Override endpoint only if needed for proxy/testing.
GA4_MP_ENDPOINT=https://www.google-analytics.com/mp/collect
